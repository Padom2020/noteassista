rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection rules
    match /users/{userId} {
      // Allow users to read and write only their own user document
      allow read, write: if isOwner(userId);
      
      // Notes subcollection rules
      match /notes/{noteId} {
        // Owner has full access
        allow read, write: if isOwner(userId);
        
        // Collaborators can read shared notes
        allow read: if isAuthenticated() && 
                       resource.data.isShared == true &&
                       resource.data.collaborators != null &&
                       request.auth.uid in resource.data.collaborators;
        
        // Collaborators with editor or owner role can write
        allow write: if isAuthenticated() && 
                        resource.data.isShared == true &&
                        resource.data.collaborators != null &&
                        request.auth.uid in resource.data.collaborators &&
                        (resource.data.collaborators[request.auth.uid].role == 'editor' || 
                         resource.data.collaborators[request.auth.uid].role == 'owner');
        
        // Allow creation of notes by owner
        allow create: if isOwner(userId);
        
        // Prevent deletion by non-owners
        allow delete: if isOwner(userId);
      }
      
      // Folders subcollection rules
      match /folders/{folderId} {
        // Allow users to read and write only their own folders
        allow read, write: if isOwner(userId);
        
        // Allow creation of folders by owner
        allow create: if isOwner(userId);
        
        // Allow deletion of folders by owner
        allow delete: if isOwner(userId);
      }
      
      // Templates subcollection rules
      match /templates/{templateId} {
        // Allow users to read and write only their own templates
        allow read, write: if isOwner(userId);
        
        // Allow creation of templates by owner
        allow create: if isOwner(userId);
        
        // Allow deletion of templates by owner
        allow delete: if isOwner(userId);
      }
      
      // Preferences subcollection rules
      match /preferences/{preferenceId} {
        // Allow users to read and write only their own preferences
        allow read, write: if isOwner(userId);
        
        // Allow creation of preferences by owner
        allow create: if isOwner(userId);
        
        // Allow deletion of preferences by owner
        allow delete: if isOwner(userId);
      }
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}