rules_version = '2';

// Firebase Storage Security Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // User-specific storage paths
    match /users/{userId}/{allPaths=**} {
      // Allow authenticated users to read and write only their own files
      allow read, write: if isOwner(userId);
    }
    
    // Drawings storage
    match /users/{userId}/drawings/{drawingId} {
      // Allow users to upload and access their own drawings
      allow read, write: if isOwner(userId);
      
      // Allow file size up to 10MB for drawings
      allow write: if isOwner(userId) && 
                      request.resource.size < 10 * 1024 * 1024;
    }
    
    // Images storage
    match /users/{userId}/images/{allPaths=**} {
      // Allow users to upload and access their own images
      allow read, write: if isOwner(userId);
      
      // Allow file size up to 5MB for images
      allow write: if isOwner(userId) && 
                      request.resource.size < 5 * 1024 * 1024;
    }
    
    // Audio storage
    match /users/{userId}/audio/{allPaths=**} {
      // Allow users to upload and access their own audio files
      allow read, write: if isOwner(userId);
      
      // Allow file size up to 25MB for audio
      allow write: if isOwner(userId) && 
                      request.resource.size < 25 * 1024 * 1024;
    }
    
    // Deny all other access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}